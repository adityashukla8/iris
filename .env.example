GOOGLE_API_KEY=your-gemini-api-key-here
PHOENIX_API_KEY=your-phoenix-system-key-here   # Create at app.phoenix.arize.com → Settings → API Keys
PHOENIX_CLIENT_URL=https://app.phoenix.arize.com/s/your-space-name
IRIS_PORT=8081
IRIS_ENV=development

# Pattern detection (Phoenix MCP read path)
PATTERN_WINDOW_MINUTES=60       # how far back Phoenix looks for spans
PATTERN_MIN_SAMPLES=3           # minimum spans in a cluster to flag it
PATTERN_HALLUCINATION_THRESHOLD=0.15

# Self-healing pipeline
HEALING_AUTO_APPROVE=true       # false = queue for human review at POST /healing/approve
HEALING_IMPROVEMENT_THRESHOLD=1.5
HEALING_PROMPT_NAME=orion-clinical-safety

# OTel batch exporter — lower delay so spans appear in Phoenix faster (default is 5000ms)
OTEL_BSP_SCHEDULE_DELAY=500
